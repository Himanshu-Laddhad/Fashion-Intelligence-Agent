# Secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/

# Packaging / tooling
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Generated outputs — ignore all contents but keep folder structure via .gitkeep
outputs/**
!outputs/.gitkeep

# H&M Kaggle dataset — large CSVs, not committed to repo
data/hm/**
!data/hm/.gitkeep

# MLflow / model artefacts
mlruns/
mlartifacts/

# Serialised model files
*.pkl
*.joblib
*.pickle

# DuckDB files
*.duckdb
*.duckdb.wal

# SQLite (MLflow tracking DB)
*.db
*.db-shm
*.db-wal

# Data files — prevent accidental large-file commits
*.parquet
*.feather
*.arrow

# Any data/ subdirectory contents (keep .gitkeep placeholders only)
data/**
!data/**/.gitkeep

# HuggingFace / sentence-transformers local model cache (if overridden into project)
.cache/
models/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Local agent/context docs
AGENT_CONTEXT.md
GEMINI_RULES.md
